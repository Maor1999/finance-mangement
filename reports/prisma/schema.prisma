generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MonthlyReport {
  id              String       @id @default(uuid())
  userId          String
  salaryTotal     Decimal      @db.Decimal(12, 2)
  expenseTotal    Decimal      @db.Decimal(12, 2)
  month           Int
  year            Int
  net             Decimal      @db.Decimal(12, 2)
  createdAt       DateTime     @default(now())

  @@unique([userId, month, year])
  @@map("monthly_reports")
}
